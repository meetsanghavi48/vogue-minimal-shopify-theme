<div class="specs" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="specs__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="specs__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="specs__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="specs__grid">
        {%- for block in section.blocks -%}
          <div class="specs__row" {{ block.shopify_attributes }}>
            <dt class="specs__label">{{ block.settings.label }}</dt>
            <dd class="specs__value">{{ block.settings.value }}</dd>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .specs { background: #fff; }
  .specs__inner { max-width: 480px; margin: 0 auto; padding: 0 16px; }
  .specs__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 1.15rem; font-weight: 700;
    margin-bottom: 4px; color: #1a1a1a;
  }
  .specs__subheading {
    font-size: 0.8rem; font-weight: 500;
    color: #999; margin-bottom: 16px;
  }
  .specs__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .specs__row {
    display: flex;
    flex-direction: column;
    padding: 14px 0;
    border-bottom: 1px solid #eee;
  }
  .specs__row:nth-last-child(-n+2) { border-bottom: none; }
  .specs__label {
    font-size: 13px; font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 2px;
  }
  .specs__value {
    font-size: 13px;
    color: #666;
    margin: 0;
  }
  @media (min-width: 768px) {
    .specs__inner { max-width: 900px; }
  }
</style>

{% schema %}
{
  "name": "Specs Table",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product Specifications" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 60, "step": 4, "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 60, "step": 4, "default": 24 }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Specification",
      "limit": 20,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Fit" },
        { "type": "text", "id": "value", "label": "Value", "default": "Straight Fit" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Specs Table",
      "blocks": [
        { "type": "spec", "settings": { "label": "Fit", "value": "Straight Fit (Classic Comfort)" } },
        { "type": "spec", "settings": { "label": "Fabric", "value": "98% Cotton 2% Spandex" } },
        { "type": "spec", "settings": { "label": "Rise", "value": "Mid Rise" } },
        { "type": "spec", "settings": { "label": "Pockets", "value": "5" } },
        { "type": "spec", "settings": { "label": "Closure", "value": "Zip Fly + Button" } },
        { "type": "spec", "settings": { "label": "Weight", "value": "380 GSM" } }
      ]
    }
  ]
}
{% endschema %}
