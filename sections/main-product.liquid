{{ 'product-page.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign has_sizes = false -%}
{%- assign size_option_index = 0 -%}
{%- for option in product.options_with_values -%}
  {%- assign opt_down = option.name | downcase -%}
  {%- if opt_down contains 'size' -%}
    {%- assign has_sizes = true -%}
    {%- assign size_option_index = forloop.index0 -%}
  {%- endif -%}
{%- endfor -%}

<section class="pdp" data-section-id="{{ section.id }}">

  <div class="pdp__image-layer" id="pdp-image-layer">
    <div class="pdp__carousel" id="pdp-carousel">
      {%- for media in product.media -%}
        <div class="pdp__slide{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" data-type="{{ media.media_type }}">
          {%- if media.media_type == 'video' -%}
            <video class="pdp__video" autoplay muted loop playsinline preload="auto"
              poster="{{ media.preview_image | image_url: width: 1000 }}">
              {%- for source in media.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif media.media_type == 'external_video' -%}
            <div class="pdp__external-video">
              {{ media | external_video_tag: autoplay: true, mute: true, loop: true }}
            </div>
          {%- else -%}
            <img
              src="{{ media | image_url: width: 1000 }}"
              alt="{{ media.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="1000"
              height="{{ 1000 | divided_by: media.aspect_ratio | round }}"
              class="pdp__image"
              draggable="false"
            >
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if product.media.size > 1 -%}
      <button class="pdp__side-arrow pdp__side-arrow--left" id="pdp-prev" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="pdp__side-arrow pdp__side-arrow--right" id="pdp-next" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}
  </div>

  <div class="pdp__sheet" id="pdp-sheet">
    <div class="pdp__sheet-handle"><span class="pdp__handle-bar"></span></div>

    <div class="pdp__sheet-content">
      <div class="pdp__sheet-body" id="pdp-sheet-body">

        <h1 class="pdp__name">{{ product.title }}</h1>

        <div class="pdp__price-line">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <s class="pdp__compare-price">{{ current_variant.compare_at_price | money }}</s>
          {%- endif -%}
          <span class="pdp__price" id="pdp-price">{{ current_variant.price | money }}</span>
        </div>

        <div class="pdp__rating">
          <span class="jdgm-preview-badge" data-id="{{ product.id }}">
            {{ product.metafields.judgeme.badge }}
          </span>
        </div>

      {%- comment -%} Feature badges in rounded container {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="pdp__features-card">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="pdp__feature" {{ block.shopify_attributes }}>
                <div class="pdp__feature-icon">
                  {%- if block.settings.custom_icon != blank -%}
                    <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" width="24" height="24" loading="lazy">
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'star' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- when 'shield' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- when 'layers' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                      {%- when 'refresh' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                      {%- when 'heart' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                      {%- when 'truck' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      {%- when 'check' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                      {%- when 'award' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                      {%- when 'droplet' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
                      {%- when 'zap' -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                      {%- else -%}
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
                <span class="pdp__feature-text">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id">

        {%- comment -%} Sizes panel — inside scrollable body {%- endcomment -%}
        {%- if has_sizes -%}
          <div class="pdp__sizes-panel" id="sizes-panel" hidden>
            <div class="pdp__sizes-row">
              {%- for option in product.options_with_values -%}
                {%- assign opt_down = option.name | downcase -%}
                {%- if opt_down contains 'size' -%}
                  {%- for value in option.values -%}
                    <button type="button" class="pdp__size-chip"
                      data-option-index="{{ size_option_index }}"
                      data-value="{{ value }}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Colors {%- endcomment -%}
        {%- for option in product.options_with_values -%}
          {%- assign opt_down = option.name | downcase -%}
          {%- if opt_down contains 'color' or opt_down contains 'colour' -%}
            <div class="pdp__color-row">
              <span class="pdp__color-label">Colour</span>
              <div class="pdp__swatches">
                {%- for value in option.values -%}
                  {%- assign color_handle = value | handleize -%}
                  <button type="button"
                    class="pdp__color-swatch swatch--{{ color_handle }}{% if forloop.first %} is-selected{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value }}"
                    aria-label="{{ value }}" title="{{ value }}"></button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>{%- comment -%} end pdp__sheet-body {%- endcomment -%}

      <div class="pdp__sheet-footer">
        <button type="button" class="pdp__smart-btn" id="btn-smart"
          data-has-sizes="{{ has_sizes }}"
          data-state="{% if has_sizes %}select{% else %}ready{% endif %}">
          {%- if has_sizes -%}
            Select Size
          {%- elsif current_variant.available -%}
            Add to my bag
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      </div>

    </div>
  </div>

</section>

<script type="application/json" id="product-variants-json">
  {{ product.variants | json }}
</script>

<script src="{{ 'variant-selector.js' | asset_url }}" defer></script>
<script src="{{ 'product-gallery.js' | asset_url }}" defer></script>
<script src="{{ 'cart-api.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "url",
      "id": "size_chart_url",
      "label": "Size chart page URL"
    },
    {
      "type": "text",
      "id": "add_button_text",
      "label": "Add to cart button text",
      "default": "Add to my bag"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Badge",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Built-in icon",
          "options": [
            { "value": "star", "label": "Star (Rating)" },
            { "value": "shield", "label": "Shield (Protection)" },
            { "value": "layers", "label": "Layers (Quality)" },
            { "value": "refresh", "label": "Refresh (Returns)" },
            { "value": "heart", "label": "Heart (Comfort)" },
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "check", "label": "Check (Verified)" },
            { "value": "award", "label": "Award (Premium)" },
            { "value": "droplet", "label": "Droplet (Waterproof)" },
            { "value": "zap", "label": "Zap (Fast)" }
          ],
          "default": "star"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon image (overrides built-in)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label text",
          "default": "Comfort"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Page",
      "blocks": [
        { "type": "feature", "settings": { "icon": "star", "text": "4.6 /5" } },
        { "type": "feature", "settings": { "icon": "layers", "text": "Comfort" } },
        { "type": "feature", "settings": { "icon": "shield", "text": "Durable" } },
        { "type": "feature", "settings": { "icon": "refresh", "text": "Adaptive" } }
      ]
    }
  ]
}
{% endschema %}
