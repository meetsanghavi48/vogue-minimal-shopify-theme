{{ 'product-page.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign has_sizes = false -%}
{%- assign size_option_index = 0 -%}
{%- for option in product.options_with_values -%}
  {%- assign opt_down = option.name | downcase -%}
  {%- if opt_down contains 'size' -%}
    {%- assign has_sizes = true -%}
    {%- assign size_option_index = forloop.index0 -%}
  {%- endif -%}
{%- endfor -%}

{%- assign discount_pct = 0 -%}
{%- if current_variant.compare_at_price > current_variant.price -%}
  {%- assign diff = current_variant.compare_at_price | minus: current_variant.price -%}
  {%- assign discount_pct = diff | times: 100 | divided_by: current_variant.compare_at_price -%}
{%- endif -%}

<section class="pdp" data-section-id="{{ section.id }}">

  {%- comment -%}
    =============================================
    LAYER 1 — FIXED IMAGE CAROUSEL
    =============================================
  {%- endcomment -%}
  <div class="pdp__image-layer" id="pdp-image-layer">
    <div class="pdp__carousel" id="pdp-carousel">
      {%- for media in product.media -%}
        <div class="pdp__slide{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" data-type="{{ media.media_type }}">
          {%- if media.media_type == 'video' -%}
            <video class="pdp__video" autoplay muted loop playsinline preload="auto"
              poster="{{ media.preview_image | image_url: width: 1200 }}">
              {%- for source in media.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif media.media_type == 'external_video' -%}
            <div class="pdp__external-video">
              {{ media | external_video_tag: autoplay: true, mute: true, loop: true }}
            </div>
          {%- else -%}
            <img
              src="{{ media | image_url: width: 1200 }}"
              alt="{{ media.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="1200"
              height="{{ 1200 | divided_by: media.aspect_ratio | round }}"
              class="pdp__image"
              draggable="false"
            >
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if product.media.size > 1 -%}
      <button class="pdp__side-arrow pdp__side-arrow--left" id="pdp-prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="pdp__side-arrow pdp__side-arrow--right" id="pdp-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <div class="pdp__dots" id="pdp-dots">
        {%- for media in product.media -%}
          <span class="pdp__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if discount_pct > 0 -%}
      <div class="pdp__badge">-{{ discount_pct }}%</div>
    {%- endif -%}
  </div>

  {%- comment -%}
    =============================================
    LAYER 2 — THE WHITE SHEET (SCROLLABLE)
    =============================================
  {%- endcomment -%}
  <div class="pdp__sheet" id="pdp-sheet">
    <div class="pdp__sheet-handle"><span class="pdp__handle-bar"></span></div>

    <div class="pdp__sheet-content">

      {%- comment -%} — PURCHASE ZONE — {%- endcomment -%}
      <div class="pdp__purchase-zone">
        <h1 class="pdp__name">{{ product.title }}</h1>

        <div class="pdp__meta-row">
          <div class="pdp__price-block">
            <span class="pdp__price" id="pdp-price">{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <s class="pdp__compare-price">{{ current_variant.compare_at_price | money }}</s>
              <span class="pdp__save-badge">Save {{ discount_pct }}%</span>
            {%- endif -%}
          </div>
          <div class="pdp__rating">
            <span class="jdgm-preview-badge" data-id="{{ product.id }}">
              {{ product.metafields.judgeme.badge }}
            </span>
          </div>
        </div>

        {%- comment -%} Feature badges {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          {%- assign feature_blocks = section.blocks | where: "type", "feature" -%}
          {%- if feature_blocks.size > 0 -%}
            <div class="pdp__features-card" style="--features-bg: {{ section.settings.features_bg_color }}">
              {%- for block in feature_blocks -%}
                <div class="pdp__feature" {{ block.shopify_attributes }}>
                  <div class="pdp__feature-icon">
                    {%- if block.settings.custom_icon != blank -%}
                      <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" width="24" height="24" loading="lazy">
                    {%- else -%}
                      {%- case block.settings.icon -%}
                        {%- when 'star' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {%- when 'shield' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        {%- when 'layers' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                        {%- when 'refresh' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                        {%- when 'heart' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                        {%- when 'truck' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'check' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        {%- when 'award' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                        {%- when 'droplet' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
                        {%- when 'zap' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                        {%- else -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
                      {%- endcase -%}
                    {%- endif -%}
                  </div>
                  <span class="pdp__feature-text">{{ block.settings.text }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id">

        {%- comment -%} Colors {%- endcomment -%}
        {%- for option in product.options_with_values -%}
          {%- assign opt_down = option.name | downcase -%}
          {%- if opt_down contains 'color' or opt_down contains 'colour' -%}
            <div class="pdp__color-row">
              <span class="pdp__color-label">Colour</span>
              <div class="pdp__swatches">
                {%- for value in option.values -%}
                  {%- assign color_handle = value | handleize -%}
                  <button type="button"
                    class="pdp__color-swatch swatch--{{ color_handle }}{% if forloop.first %} is-selected{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value }}"
                    aria-label="{{ value }}" title="{{ value }}"></button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Size + Add to Cart row {%- endcomment -%}
        <div class="pdp__bottom-row">
          {%- if has_sizes -%}
            <button type="button" class="pdp__size-btn" id="size-trigger" data-option-index="{{ size_option_index }}">
              <span class="pdp__select-label">Size</span>
              <svg class="pdp__select-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          {%- endif -%}

          <button type="button" class="pdp__add-btn" id="btn-add" data-has-sizes="{{ has_sizes }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <span>{{ section.settings.add_button_text | default: 'Add to bag' }}</span>
          </button>
        </div>
      </div>

      <!-- DEBUG TEST -->
      <div style="padding:20px;background:#ffe0e0;border-radius:12px;margin-top:16px;text-align:center;font-weight:700;">
        TEST: If you can see this red box, scroll sections are rendering.
      </div>

      {%- comment -%}
        =============================================
        SCROLL SECTION 1 — URGENCY + SOCIAL PROOF
        =============================================
      {%- endcomment -%}
      <div class="pdp__scroll-section pdp__social-proof reveal-on-scroll" data-delay="0">
        <div class="pdp__proof-items">
          <div class="pdp__proof-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <span><strong id="viewer-count">{{ section.settings.viewers_min | default: 12 }}</strong> people viewing now</span>
          </div>
          <div class="pdp__proof-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <span><strong id="recent-sold">{{ section.settings.sold_count | default: 47 }}</strong> sold in last 24h</span>
          </div>
          <div class="pdp__proof-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Order within <strong id="countdown-timer">2h 34m</strong> for dispatch today</span>
          </div>
        </div>
      </div>

      {%- comment -%}
        =============================================
        SCROLL SECTION 2 — THE PROMISE (BOLD STATEMENT)
        =============================================
      {%- endcomment -%}
      {%- if section.settings.promise_heading != blank -%}
        <div class="pdp__scroll-section pdp__promise reveal-on-scroll" data-delay="100">
          <div class="pdp__promise-inner">
            <span class="pdp__promise-eyebrow">{{ section.settings.promise_eyebrow | default: 'The Promise' }}</span>
            <h2 class="pdp__promise-heading">{{ section.settings.promise_heading }}</h2>
            {%- if section.settings.promise_subtext != blank -%}
              <p class="pdp__promise-sub">{{ section.settings.promise_subtext }}</p>
            {%- endif -%}
          </div>
          {%- if section.settings.promise_image != blank -%}
            <img src="{{ section.settings.promise_image | image_url: width: 800 }}" alt="" class="pdp__promise-img" loading="lazy">
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%}
        =============================================
        SCROLL SECTION 3 — TRUST STACK
        =============================================
      {%- endcomment -%}
      <div class="pdp__scroll-section pdp__trust-stack reveal-on-scroll" data-delay="0">
        {%- assign trust_blocks = section.blocks | where: "type", "trust_item" -%}
        {%- if trust_blocks.size > 0 -%}
          {%- for block in trust_blocks -%}
            <div class="pdp__trust-item reveal-on-scroll" data-delay="{{ forloop.index0 | times: 80 }}" {{ block.shopify_attributes }}>
              <div class="pdp__trust-icon">
                {%- if block.settings.custom_icon != blank -%}
                  <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="" width="28" height="28" loading="lazy">
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'truck' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    {%- when 'refresh' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                    {%- when 'shield' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    {%- when 'credit-card' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    {%- when 'check' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {%- else -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
              <div class="pdp__trust-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}
                  <span>{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="pdp__trust-item reveal-on-scroll" data-delay="0">
            <div class="pdp__trust-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
            <div class="pdp__trust-text"><strong>Free Shipping</strong><span>All over India</span></div>
          </div>
          <div class="pdp__trust-item reveal-on-scroll" data-delay="80">
            <div class="pdp__trust-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg></div>
            <div class="pdp__trust-text"><strong>7 Day Returns</strong><span>Free return shipping</span></div>
          </div>
          <div class="pdp__trust-item reveal-on-scroll" data-delay="160">
            <div class="pdp__trust-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
            <div class="pdp__trust-text"><strong>COD Available</strong><span>Pay on delivery</span></div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%}
        =============================================
        SCROLL SECTION 4 — PRODUCT DESCRIPTION
        =============================================
      {%- endcomment -%}
      {%- if product.description != blank -%}
        <div class="pdp__scroll-section pdp__description reveal-on-scroll" data-delay="0">
          <button type="button" class="pdp__desc-toggle" id="desc-toggle" aria-expanded="false">
            <span class="pdp__desc-toggle-label">About this product</span>
            <svg class="pdp__desc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="pdp__desc-content" id="desc-content">
            <div class="pdp__desc-text rte">
              {{ product.description }}
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%}
        =============================================
        SCROLL SECTION 5 — CUSTOMER REVIEWS
        =============================================
      {%- endcomment -%}
      <div class="pdp__scroll-section pdp__reviews reveal-on-scroll" data-delay="0">
        <h3 class="pdp__section-title">What customers say</h3>
        <div id="judgeme_product_reviews" data-id="{{ product.id }}">
          {{ product.metafields.judgeme.widget }}
        </div>
      </div>

      {%- comment -%}
        =============================================
        SCROLL SECTION 6 — YOU MAY ALSO LIKE
        =============================================
      {%- endcomment -%}
      <div class="pdp__scroll-section pdp__related reveal-on-scroll" data-delay="0">
        <h3 class="pdp__section-title">You may also like</h3>
        <div class="pdp__related-grid" id="pdp-related">
          {%- for rec in recommendations.products limit: 4 -%}
            <a href="{{ rec.url }}" class="pdp__rec-card">
              <div class="pdp__rec-img-wrap">
                <img src="{{ rec.featured_image | image_url: width: 400 }}" alt="{{ rec.title | escape }}" loading="lazy" class="pdp__rec-img">
              </div>
              <div class="pdp__rec-info">
                <span class="pdp__rec-title">{{ rec.title }}</span>
                <span class="pdp__rec-price">{{ rec.price | money }}</span>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>

  {%- comment -%}
    =============================================
    SIZE SELECTION MODAL
    =============================================
  {%- endcomment -%}
  {%- if has_sizes -%}
    <div class="size-modal__backdrop" id="size-modal-backdrop" hidden>
      <div class="size-modal" id="size-modal">
        <div class="size-modal__header">
          <h2 class="size-modal__title">Select Size</h2>
          <button type="button" class="size-modal__close" id="size-modal-close" aria-label="Close">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        {%- if section.settings.size_chart_page != blank -%}
          <div class="size-modal__chart">
            <h3 class="size-modal__chart-title">Size Guide</h3>
            <div class="size-modal__chart-content">
              {{ pages[section.settings.size_chart_page].content }}
            </div>
          </div>
        {%- endif -%}

        <div class="size-modal__sizes" id="size-modal-options">
          <h3 class="size-modal__sizes-title">Choose your size</h3>
          <div class="size-modal__pills">
            {%- for option in product.options_with_values -%}
              {%- assign opt_down = option.name | downcase -%}
              {%- if opt_down contains 'size' -%}
                {%- for value in option.values -%}
                  <button type="button" class="size-modal__pill" data-value="{{ value }}" data-option-index="{{ forloop.parentloop.index0 }}">
                    {{ value }}
                  </button>
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <button type="button" class="size-modal__confirm" id="size-modal-confirm" disabled>
          Select a size
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}
    =============================================
    STICKY BUY BAR — appears after scrolling past hero
    =============================================
  {%- endcomment -%}
  <div class="pdp__sticky-bar" id="pdp-sticky-bar">
    <div class="pdp__sticky-inner">
      <div class="pdp__sticky-info">
        <span class="pdp__sticky-name">{{ product.title | truncate: 25 }}</span>
        <span class="pdp__sticky-price">{{ current_variant.price | money }}</span>
      </div>
      <button type="button" class="pdp__sticky-buy" id="sticky-buy" data-has-sizes="{{ has_sizes }}">
        Add to bag
      </button>
    </div>
  </div>

</section>

<script type="application/json" id="product-variants-json">
  {{ product.variants | json }}
</script>

<script src="{{ 'variant-selector.js' | asset_url }}" defer></script>
<script src="{{ 'product-gallery.js' | asset_url }}" defer></script>
<script src="{{ 'product-scroll.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "page",
      "id": "size_chart_page",
      "label": "Size chart page"
    },
    {
      "type": "text",
      "id": "add_button_text",
      "label": "Add to cart button text",
      "default": "Add to bag"
    },
    {
      "type": "color",
      "id": "features_bg_color",
      "label": "Features card background",
      "default": "transparent"
    },
    {
      "type": "header",
      "content": "Social Proof"
    },
    {
      "type": "range",
      "id": "viewers_min",
      "label": "Minimum viewers count",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "sold_count",
      "label": "Sold in last 24h",
      "min": 10,
      "max": 200,
      "step": 1,
      "default": 47
