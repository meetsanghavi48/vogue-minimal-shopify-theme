<div class="reviews-section" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="reviews-section__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="reviews-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="reviews-section__widget" id="judgeme-reviews-{{ section.id }}">
      {{ product.metafields.judgeme.widget }}
    </div>
  </div>
</div>

<style>
  .reviews-section { background: #fff; }
  .reviews-section__inner { max-width: 480px; margin: 0 auto; padding: 0 16px; }
  .reviews-section__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 1.15rem; font-weight: 700;
    margin-bottom: 16px; color: #1a1a1a;
  }
  @media (min-width: 768px) {
    .reviews-section__inner { max-width: 900px; }
  }
</style>

{% schema %}
{
  "name": "Product Reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Reviews" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 60, "step": 4, "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 60, "step": 4, "default": 24 }
  ],
  "presets": [{ "name": "Product Reviews" }]
}
{% endschema %}
