<section class="page-section">
  <div class="container section-spacing" style="text-align:center;">
    <h1>{{ shop.name }}</h1>
    <p>This store is coming soon.</p>
    {%- form 'storefront_password' -%}
      <div style="margin-top:1.5rem;">
        <input type="password" name="password" placeholder="Enter password" style="padding:0.75rem 1rem;border:1.5px solid #ddd;border-radius:999px;font-size:1rem;">
        <button type="submit" class="btn btn--primary" style="margin-left:0.5rem;">Enter</button>
      </div>
      {%- if form.errors -%}
        <p style="color:red;margin-top:0.5rem;">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Password Page",
  "settings": [],
  "templates": ["password"]
}
{% endschema %}
