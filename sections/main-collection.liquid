<section class="page-section">
  <div class="container section-spacing">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description }}</p>
    {%- endif -%}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.5rem;margin-top:2rem;">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" style="width:100%;border-radius:12px;">
          {%- endif -%}
          <h3 style="font-size:0.9rem;margin-top:0.5rem;">{{ product.title }}</h3>
          <p style="font-size:0.85rem;color:#666;">{{ product.price | money }}</p>
        </a>
      {%- endfor -%}
    </div>
    {%- if collection.products.size == 0 -%}
      <p>No products in this collection.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "settings": [],
  "templates": ["collection"]
}
{% endschema %}
