{%- if recommendations.performed and recommendations.products_count > 0 -%}
<div class="reco" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="reco__inner">
    <h2 class="reco__heading">{{ section.settings.heading | default: 'Recommended for you' }}</h2>
    <div class="reco__scroll">
      {%- for product in recommendations.products limit: section.settings.limit -%}
        <a href="{{ product.url }}" class="reco__card">
          <div class="reco__img-wrap">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy" width="200" height="260">
            {%- endif -%}
          </div>
          <div class="reco__info">
            <h3 class="reco__title">{{ product.title }}</h3>
            <div class="reco__prices">
              <span class="reco__price">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <s class="reco__compare">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>
            <button class="reco__add" onclick="event.preventDefault();fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:{{ product.selected_or_first_available_variant.id }},quantity:1}]})}).then(()=>{this.textContent='Added!';setTimeout(()=>this.textContent='+ Add',1500)})">
              + Add
            </button>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

<style>
  .reco { background: #fff; }
  .reco__inner { max-width: 480px; margin: 0 auto; padding: 0 16px; }
  .reco__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 16px;
    color: #1a1a1a;
  }
  .reco__scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .reco__scroll::-webkit-scrollbar { display: none; }
  .reco__card {
    flex: 0 0 72%;
    scroll-snap-align: start;
    display: flex;
    gap: 12px;
    padding: 12px;
    background: #fafafa;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease;
  }
  .reco__card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .reco__img-wrap {
    flex: 0 0 80px;
    border-radius: 8px;
    overflow: hidden;
    background: #eee;
  }
  .reco__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .reco__info { flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
  .reco__title { font-size: 13px; font-weight: 600; line-height: 1.3; margin-bottom: 4px; color: #1a1a1a; }
  .reco__prices { display: flex; align-items: baseline; gap: 6px; margin-bottom: 8px; }
  .reco__price { font-size: 13px; font-weight: 700; color: #1a1a1a; }
  .reco__compare { font-size: 11px; color: #999; text-decoration: line-through; }
  .reco__add {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 6px 20px;
    font-size: 12px; font-weight: 700; font-family: inherit;
    color: #fff;
    background: #1a1a1a;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease;
    align-self: flex-start;
  }
  .reco__add:hover { background: #333; }
  @media (min-width: 768px) {
    .reco__inner { max-width: 900px; }
    .reco__card { flex: 0 0 45%; }
  }
</style>

{% schema %}
{
  "name": "Recommended Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recommended for you" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 2, "max": 10, "step": 1, "default": 6 },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 60, "step": 4, "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 60, "step": 4, "default": 20 }
  ],
  "presets": [{ "name": "Recommended Products" }]
}
{% endschema %}
