<section class="page-section">
  <div class="container section-spacing">
    <h1>Search</h1>
    <form action="/search" method="get" style="margin:1.5rem 0;">
      <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Search..." style="width:100%;padding:0.75rem 1rem;border:1.5px solid #ddd;border-radius:999px;font-size:1rem;">
    </form>
    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        {%- for result in search.results -%}
          <div style="padding:1rem 0;border-bottom:1px solid #eee;">
            <a href="{{ result.url }}" style="font-weight:600;">{{ result.title }}</a>
            <p style="font-size:0.85rem;color:#666;">{{ result.content | strip_html | truncatewords: 20 }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p>No results found for "{{ search.terms }}".</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search Page",
  "settings": [],
  "templates": ["search"]
}
{% endschema %}
