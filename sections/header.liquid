<header class="site-header" role="banner">
  <div class="container header__inner">
    <a href="/" class="header__logo">
      {%- if section.settings.logo -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="100"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="header__store-name">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="header__nav" role="navigation">
      <a href="/collections/all" class="header__link">Shop</a>
      <a href="/cart" class="header__cart" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="header__cart-count" id="cart-count">{{ cart.item_count }}</span>
      </a>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
