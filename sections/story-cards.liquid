<div class="story-section" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="story-section__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="story-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="story-cards">
        {%- for block in section.blocks -%}
          <div class="story-card {% cycle 'story-card--img-left', 'story-card--img-right', 'story-card--img-left' %}"
            {{ block.shopify_attributes }}
            style="{% if block.settings.bg_color != blank %}background: {{ block.settings.bg_color }};{% endif %}">

            <div class="story-card__img">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  width="400"
                  height="{{ 400 | divided_by: block.settings.image.aspect_ratio | round }}"
                >
              {%- else -%}
                <div class="story-card__placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              {%- endif -%}
            </div>

            <div class="story-card__content">
              {%- if block.settings.eyebrow != blank -%}
                <span class="story-card__eyebrow">{{ block.settings.eyebrow }}</span>
              {%- endif -%}

              <h3 class="story-card__heading">{{ block.settings.heading }}</h3>

              {%- if block.settings.body != blank -%}
                <p class="story-card__body">{{ block.settings.body }}</p>
              {%- endif -%}

              {%- if block.settings.btn_text != blank -%}
                <div class="story-card__actions">
                  <a href="{{ block.settings.btn_link | default: '#' }}" class="story-card__btn story-card__btn--primary">
                    {{ block.settings.btn_text }}
                  </a>
                  {%- if block.settings.btn_text_2 != blank -%}
                    <a href="{{ block.settings.btn_link_2 | default: '#' }}" class="story-card__btn story-card__btn--secondary">
                      {{ block.settings.btn_text_2 }}
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  .story-section {
    background: #fff;
  }
  .story-section__inner {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 16px;
  }
  .story-section__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 1.25rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 20px;
  }
  .story-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* --- Card --- */
  .story-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border-radius: 16px;
    background: #f5f0eb;
    overflow: hidden;
  }
  .story-card--img-right {
    flex-direction: row-reverse;
  }

  /* --- Image --- */
  .story-card__img {
    flex: 0 0 40%;
    border-radius: 12px;
    overflow: hidden;
  }
  .story-card__img img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    object-fit: cover;
  }
  .story-card__placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: #e8e8e8;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* --- Content --- */
  .story-card__content {
    flex: 1;
    min-width: 0;
  }
  .story-card__eyebrow {
    display: block;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    margin-bottom: 4px;
  }
  .story-card__heading {
    font-family: var(--font-heading-family, serif);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 6px;
    color: #1a1a1a;
  }
  .story-card__body {
    font-size: 0.75rem;
    line-height: 1.5;
    color: #777;
    margin-bottom: 12px;
  }

  /* --- Buttons --- */
  .story-card__actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .story-card__btn {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 7px 16px;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .story-card__btn--primary {
    background: #1a1a1a;
    color: #fff;
  }
  .story-card__btn--primary:hover {
    background: #333;
  }
  .story-card__btn--secondary {
    background: transparent;
    color: #1a1a1a;
    border: 1.5px solid #ccc;
  }
  .story-card__btn--secondary:hover {
    border-color: #1a1a1a;
  }

  /* --- Desktop --- */
  @media (min-width: 768px) {
    .story-section__inner {
      max-width: 900px;
    }
    .story-card {
      padding: 24px;
      gap: 32px;
    }
    .story-card__heading {
      font-size: 1.25rem;
    }
    .story-card__body {
      font-size: 0.875rem;
    }
  }
</style>

{% schema %}
{
  "name": "Story Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Description",
          "default": "Describe the feature or benefit of your product here."
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button 1 text",
          "default": "Add To Cart"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button 1 link"
        },
        {
          "type": "text",
          "id": "btn_text_2",
          "label": "Button 2 text",
          "default": "Details"
        },
        {
          "type": "url",
          "id": "btn_link_2",
          "label": "Button 2 link"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Card background",
          "default": "#f5f0eb"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Pineapple | Holy Basil | Moringa",
            "body": "Our premium blend creates a refreshing experience with natural ingredients and essential nutrients.",
            "btn_text": "Add To Cart",
            "btn_text_2": "Details",
            "bg_color": "#e8f5e9"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Nettle | Lemon | Ginger",
            "body": "A powerful combination for immunity and making good first impressions, with natural flavoring.",
            "btn_text": "Add To Cart",
            "btn_text_2": "Details",
            "bg_color": "#fff3e0"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Peach | Yarrow | Moringa",
            "body": "Light and airy with natural peach flavor, perfect for everyday wellness.",
            "btn_text": "Add To Cart",
            "btn_text_2": "Details",
            "bg_color": "#fce4ec"
          }
        }
      ]
    }
  ]
}
{% endschema %}
