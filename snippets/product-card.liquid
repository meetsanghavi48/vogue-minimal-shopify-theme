{%- comment -%}
  Renders a product card for recommendations.

  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- if product -%}
<a href="{{ product.url }}" class="product-card">
  <div class="product-card__image-wrap">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 400 }}"
        srcset="
          {{ product.featured_image | image_url: width: 200 }} 200w,
          {{ product.featured_image | image_url: width: 400 }} 400w
        "
        sizes="(min-width: 768px) 240px, 160px"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        loading="lazy"
        width="400"
        height="{{ 400 | divided_by: product.featured_image.aspect_ratio | round }}"
        class="product-card__image"
      >
    {%- else -%}
      <div class="product-card__placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    <h3 class="product-card__title">{{ product.title }}</h3>
    <span class="product-card__vendor">{{ product.vendor }}</span>
  </div>
</a>
{%- endif -%}
